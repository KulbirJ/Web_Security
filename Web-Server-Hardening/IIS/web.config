<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS Security Configuration (web.config)
  Comprehensive HTTPS and Security Headers Configuration
  
  Location: C:\inetpub\wwwroot\web.config (or application root)
  Server: IIS 10 (Windows Server 2022)
  
  Features:
  - HTTP to HTTPS redirect (301 Permanent)
  - All modern security headers
  - TLS 1.2/1.3 enforcement
  - Directory browsing disabled
  - Server version hiding
  - Request filtering for unsafe methods
-->
<configuration>
  <system.webServer>
    
    <!-- ============================================
         1. HTTP PROTOCOL & SECURITY HEADERS
         ============================================ -->
    <httpProtocol>
      <customHeaders>
        <!-- Prevent MIME-type sniffing -->
        <add name="X-Content-Type-Options" value="nosniff" />
        
        <!-- Clickjacking protection - block framing -->
        <add name="X-Frame-Options" value="DENY" />
        
        <!-- Content Security Policy - XSS mitigation -->
        <add name="Content-Security-Policy" value="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; frame-ancestors 'none';" />
        
        <!-- Legacy XSS filter for older browsers -->
        <add name="X-XSS-Protection" value="1; mode=block" />
        
        <!-- Remove Server header banner -->
        <remove name="X-Powered-By" />
        
        <!-- HSTS - Enforce HTTPS for 1 year -->
        <add name="Strict-Transport-Security" value="max-age=31536000; includeSubDomains; preload" />
        
        <!-- Referrer Policy - Privacy -->
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
        
        <!-- Cache control - prevent caching of sensitive content -->
        <add name="Cache-Control" value="no-store, no-cache, must-revalidate" />
        <add name="Pragma" value="no-cache" />
        
        <!-- Feature/Permissions Policy - disable unnecessary browser features -->
        <add name="Permissions-Policy" value="geolocation=(), microphone=(), camera=()" />
      </customHeaders>
    </httpProtocol>

    <!-- ============================================
         2. URL REWRITING - HTTP TO HTTPS REDIRECT
         ============================================ -->
    <rewrite>
      <rules>
        <rule name="HTTP to HTTPS Redirect" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{HTTPS}" pattern="off" />
          </conditions>
          <action type="Redirect" url="https://{HTTP_HOST}/{R:1}" redirectType="Permanent" />
        </rule>
      </rules>
    </rewrite>

    <!-- ============================================
         3. SECURITY SETTINGS
         ============================================ -->
    <security>
      <!-- Remove Server Header -->
      <requestFiltering removeServerHeader="true" />
      
      <!-- Deny unsafe HTTP methods (TRACE, DELETE, etc.) -->
      <requestFiltering>
        <verbs>
          <add verb="TRACE" allowed="false" />
          <add verb="DELETE" allowed="false" />
          <add verb="TRACK" allowed="false" />
          <add verb="OPTIONS" allowed="false" />
        </verbs>
        
        <!-- Deny dangerous file extensions -->
        <fileExtensions>
          <add fileExtension=".config" allowed="false" />
          <add fileExtension=".exe" allowed="false" />
          <add fileExtension=".dll" allowed="false" />
          <add fileExtension=".asp" allowed="false" />
          <add fileExtension=".aspx" allowed="false" />
          <add fileExtension=".cer" allowed="false" />
        </fileExtensions>
      </requestFiltering>
    </security>

    <!-- ============================================
         4. DIRECTORY BROWSING
         ============================================ -->
    <directoryBrowse enabled="false" />

    <!-- ============================================
         5. STATIC FILE CACHING
         ============================================ -->
    <staticContent>
      <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAgeInSeconds="3600" />
    </staticContent>

    <!-- ============================================
         6. COMPRESSION
         ============================================ -->
    <urlCompression doStaticCompression="true" doDynamicCompression="true" />

  </system.webServer>

  <!-- ============================================
       7. APPLICATION SETTINGS
       ============================================ -->
  <appSettings>
    <!-- Ensure no debug mode in production -->
    <add key="debug" value="false" />
  </appSettings>

  <!-- ============================================
       8. COMPILATION (exclude from web)
       ============================================ -->
  <system.web>
    <compilation debug="false" targetFramework="4.8" />
    <customErrors mode="On" defaultRedirect="/Error.aspx">
      <error statusCode="404" redirect="/404.aspx" />
      <error statusCode="500" redirect="/500.aspx" />
    </customErrors>
  </system.web>

</configuration>
