<?xml version="1.0" encoding="UTF-8"?>
<!--
  F5 Advanced WAF - Scenario 3: Custom Zero-Day Signature XML
  File: attack-signature.xml
  Description: User-defined attack signature for JNDI injection (Log4Shell pattern)
  Format: ASM Policy XML compatible with F5 TMOS 17.5.x
  Usage: Import into ASM policy via GUI or TMSH
  
  This signature defines the following attack patterns:
  - jndi:ldap://
  - jndi:rmi://
  - jndi:nis://
  - jndi:iiop://
  
  Author: Senior F5 WAF Consultant
  Version: 1.0
-->

<!DOCTYPE application-security-signatures [
  <!ENTITY percent "&#x25;">
  <!ENTITY space "&#x20;">
]>

<attack-signatures>
  
  <!-- ===================================================================== -->
  <!-- ATTACK SIGNATURE 1: JNDI LDAP Injection Pattern                      -->
  <!-- ===================================================================== -->
  <attack-signature>
    <!-- Unique identifier for this signature -->
    <id>9800001</id>
    
    <!-- Signature name displayed in ASM UI -->
    <name>Custom_JNDI_LDAP_Injection</name>
    
    <!-- Human-readable description -->
    <description>Detects JNDI LDAP injection patterns (Log4Shell-style attacks)</description>
    
    <!-- Attack category classification -->
    <category>Remote Code Execution</category>
    
    <!-- Severity level: 1=Info, 2=Low, 3=Medium, 4=High, 5=Critical -->
    <severity>5</severity>
    
    <!-- Risk rating: 1-100 (100 = highest risk) -->
    <risk-rating>95</risk-rating>
    
    <!-- Application: General, Java, .NET, PHP, etc. -->
    <application>Java,General</application>
    
    <!-- Signature rule type: pattern, regex, protocol, cookie, header, etc. -->
    <sig-rule-type>pattern</sig-rule-type>
    
    <!-- Search locations where pattern should be applied -->
    <locations>
      <!-- Search pattern in request URI path and query string -->
      <location>
        <name>uri</name>
      </location>
      <!-- Search pattern in HTTP request headers -->
      <location>
        <name>headers</name>
      </location>
      <!-- Search pattern in request body (POST/PUT data) -->
      <location>
        <name>body</name>
      </location>
    </locations>
    
    <!-- Pattern matching rules -->
    <pattern-rules>
      <!-- Pattern definition -->
      <pattern-rule>
        <!-- Pattern string (case-insensitive search) -->
        <pattern>jndi:ldap://</pattern>
        
        <!-- Pattern matching is case-insensitive -->
        <case-sensitive>false</case-sensitive>
        
        <!-- Match type: contains, starts-with, ends-with, exact -->
        <match-type>contains</match-type>
        
        <!-- Enable this rule -->
        <enabled>true</enabled>
      </pattern-rule>
    </pattern-rules>
    
    <!-- Action to take when signature matches -->
    <action>block</action>
    
    <!-- Log when signature matches -->
    <log>true</log>
    
    <!-- Custom violation message -->
    <violation-name>Custom_ZeroDay_Command_Injection</violation-name>
    
    <!-- Risk indication (influences learning/blocking recommendations) -->
    <risk-indication>confirmed</risk-indication>
    
  </attack-signature>
  
